<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.BuddyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:HermesDesktop.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="Buddy" Style="{StaticResource PageEyebrowTextStyle}"/>
            <TextBlock Text="Your Companion" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="Craft the look, hatch the soul, then keep the same companion across sessions."
                       FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"/>
        </StackPanel>

        <Grid x:Name="SetupPanel" Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SurfaceCardStyle}" Padding="24" VerticalAlignment="Top">
                <StackPanel Spacing="16">
                    <TextBlock Text="Hatch your buddy" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentTextBrush}"/>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Species" Style="{StaticResource LabelTextStyle}"/>
                        <ComboBox x:Name="SpeciesCombo" HorizontalAlignment="Stretch"
                                  AutomationProperties.Name="Buddy species"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Palette" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox x:Name="PaletteCombo" HorizontalAlignment="Stretch"
                                      AutomationProperties.Name="Buddy palette"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock Text="Eyes" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox x:Name="EyesCombo" HorizontalAlignment="Stretch"
                                      AutomationProperties.Name="Buddy eyes"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Accessory" Style="{StaticResource LabelTextStyle}"/>
                        <ComboBox x:Name="AccessoryCombo" HorizontalAlignment="Stretch"
                                  AutomationProperties.Name="Buddy accessory"/>
                    </StackPanel>

                    <Button x:Name="HatchButton" Content="Hatch buddy" Click="HatchButton_Click"
                            Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="SetupStatusText" FontSize="12" TextWrapping="Wrap"
                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <controls:BuddyAvatarView x:Name="SetupAvatar" Width="360" Height="360"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" x:Name="SetupPreviewText" TextWrapping="Wrap" TextAlignment="Center"
                               FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="MainBuddyGrid" Grid.Row="1" Visibility="Collapsed" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource SurfaceCardStyle}" Padding="28">
                <Grid RowSpacing="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <controls:BuddyAvatarView x:Name="MainAvatar" Width="420" Height="420"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <StackPanel Grid.Row="1" Spacing="8" HorizontalAlignment="Center">
                        <TextBlock x:Name="ShinyBadge" Text="SHINY" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource AppAccentTextBrush}"
                                   Visibility="Collapsed"/>
                        <TextBlock x:Name="BuddyName" Text="..." FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource AppAccentTextBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                            <TextBlock x:Name="BuddySpecies" Text="" FontSize="14"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <Border x:Name="RarityBadge" Background="{StaticResource AppOutlineBrush}"
                                    CornerRadius="6" Padding="10,4">
                                <TextBlock x:Name="RarityText" Text="" FontSize="11"
                                           Foreground="{StaticResource AppAccentTextBrush}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="BuddyPersonality" Text="" FontSize="13" TextWrapping="Wrap"
                                   TextAlignment="Center" FontStyle="Italic" MaxWidth="520"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    </StackPanel>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="18">
                        <Border Background="{StaticResource AppInsetBrush}" CornerRadius="8" Padding="20,16">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="54,*,42" RowSpacing="10">
                                <TextBlock Text="INT" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" VerticalAlignment="Center"/>
                                <ProgressBar x:Name="StatInt" Grid.Column="1" Minimum="0" Maximum="100" Value="0"
                                             Height="8" Margin="8,0" CornerRadius="4"
                                             Foreground="{StaticResource BuddyStatIntBrush}" Background="{StaticResource ProgressTrackBrush}"/>
                                <TextBlock x:Name="StatIntVal" Grid.Column="2" Text="0" FontSize="12"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Text="ENR" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" VerticalAlignment="Center"/>
                                <ProgressBar x:Name="StatEnr" Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="0"
                                             Height="8" Margin="8,0" CornerRadius="4"
                                             Foreground="{StaticResource BuddyStatEnrBrush}" Background="{StaticResource ProgressTrackBrush}"/>
                                <TextBlock x:Name="StatEnrVal" Grid.Row="1" Grid.Column="2" Text="0" FontSize="12"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Text="CRE" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" VerticalAlignment="Center"/>
                                <ProgressBar x:Name="StatCre" Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" Value="0"
                                             Height="8" Margin="8,0" CornerRadius="4"
                                             Foreground="{StaticResource BuddyStatCreBrush}" Background="{StaticResource ProgressTrackBrush}"/>
                                <TextBlock x:Name="StatCreVal" Grid.Row="2" Grid.Column="2" Text="0" FontSize="12"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="3" Text="FRN" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" VerticalAlignment="Center"/>
                                <ProgressBar x:Name="StatFrn" Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="100" Value="0"
                                             Height="8" Margin="8,0" CornerRadius="4"
                                             Foreground="{StaticResource BuddyStatFrnBrush}" Background="{StaticResource ProgressTrackBrush}"/>
                                <TextBlock x:Name="StatFrnVal" Grid.Row="3" Grid.Column="2" Text="0" FontSize="12"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button x:Name="RefreshSoulButton" Content="Refresh personality" Click="RefreshSoulButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button x:Name="ResetBuddyButton" Content="Reset buddy..." Click="ResetBuddyButton_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Spacing="16">
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Craft" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AppAccentTextBrush}"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Palette" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="EditPaletteCombo" SelectionChanged="EditCraft_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="Eyes" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="EditEyesCombo" SelectionChanged="EditCraft_SelectionChanged"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Accessory" Style="{StaticResource LabelTextStyle}"/>
                            <ComboBox x:Name="EditAccessoryCombo" SelectionChanged="EditCraft_SelectionChanged"/>
                        </StackPanel>
                        <Button x:Name="SaveLookButton" Content="Save look" Click="SaveLookButton_Click"
                                Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="BuddyActionStatus" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SurfaceCardStyle}" Padding="20">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Details" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AppAccentTextBrush}"/>
                        <TextBlock Text="Rarity controls the base stats. Crafting changes only the visual avatar, so you can tune the character without rerolling the companion."
                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <Border Background="{StaticResource AppInsetBrush}" CornerRadius="8" Padding="16,12">
                            <TextBlock x:Name="BuddyDetails" FontSize="12"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"
                                       FontFamily="Consolas" TextWrapping="Wrap" Text="Loading..."/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
