<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.IntegrationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d"
    NavigationCacheMode="Required">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,24,32,40" Spacing="20">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock
                        x:Uid="IntegrationsEyebrow"
                        Style="{StaticResource PageEyebrowTextStyle}" />
                    <TextBlock
                        x:Uid="IntegrationsTitle"
                        Style="{StaticResource PageTitleTextStyle}"
                        MaxWidth="920" />
                    <TextBlock
                        x:Uid="IntegrationsSubtitle"
                        Style="{StaticResource BodySecondaryTextStyle}"
                        MaxWidth="920" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock
                            x:Uid="IntegrationsTelegramTitle"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            Style="{StaticResource MetricValueTextStyle}"
                            Text="{x:Bind TelegramStatus, Mode=OneTime}" />
                        <TextBlock
                            x:Uid="IntegrationsTelegramDetail"
                            Style="{StaticResource BodySecondaryTextStyle}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock
                            x:Uid="IntegrationsDiscordTitle"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            Style="{StaticResource MetricValueTextStyle}"
                            Text="{x:Bind DiscordStatus, Mode=OneTime}" />
                        <TextBlock
                            x:Uid="IntegrationsDiscordDetail"
                            Style="{StaticResource BodySecondaryTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock
                        x:Uid="IntegrationsGatewayTitle"
                        Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock
                        x:Uid="IntegrationsGatewayLine1"
                        Style="{StaticResource BodySecondaryTextStyle}" />
                    <TextBlock
                        x:Uid="IntegrationsGatewayLine2"
                        Style="{StaticResource BodySecondaryTextStyle}" />
                    <TextBlock
                        x:Uid="IntegrationsGatewayLine3"
                        Style="{StaticResource BodySecondaryTextStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Uid="IntegrationsOpenLogsButton"
                            AccessKey="G"
                            AutomationProperties.AutomationId="IntegrationsOpenLogsButton"
                            Background="{StaticResource AppInsetBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            Click="OpenLogs_Click"
                            Foreground="White" />
                        <Button
                            x:Uid="IntegrationsOpenConfigButton"
                            AccessKey="C"
                            AutomationProperties.AutomationId="IntegrationsOpenConfigButton"
                            Background="{StaticResource AppInsetBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            Click="OpenConfig_Click"
                            Foreground="White" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
