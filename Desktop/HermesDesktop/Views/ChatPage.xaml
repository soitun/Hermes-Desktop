<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:HermesDesktop.Models"
    xmlns:panels="using:HermesDesktop.Views.Panels"
    Background="Transparent"
    Loaded="OnPageLoaded"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <!-- Enter sends, Shift+Enter for newline (handled in KeyDown) -->

    <Grid x:Name="MainGrid" Padding="20,12,24,20" ColumnSpacing="14" RowSpacing="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="340" MinWidth="200" MaxWidth="700"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Grid.ColumnSpan="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="Hermes Agent" FontSize="22" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="ConnectionStateText" Style="{StaticResource BodySecondaryTextStyle}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="New Chat" Click="NewChat_Click" Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppSubtleStrokeBrush}" Foreground="White" />
            </StackPanel>
        </Grid>

        <!-- Main Chat Area -->
        <Border Grid.Row="1" Style="{StaticResource SurfaceCardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Messages -->
                <ListView x:Name="MessagesList" Grid.Row="1" Padding="18" Background="Transparent" BorderThickness="0"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ChatMessageItem">
                            <Grid Margin="0,0,0,10">
                                <Border MaxWidth="780" HorizontalAlignment="{x:Bind BubbleAlignment}"
                                    Background="{x:Bind BubbleBackground}" BorderBrush="{x:Bind BubbleBorderBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="16,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Foreground="{x:Bind LabelBrush}" Style="{StaticResource LabelTextStyle}" Text="{x:Bind AuthorLabel}" />

                                        <!-- Thinking/reasoning content (collapsible) -->
                                        <Expander Visibility="{x:Bind HasThinking, Mode=OneWay}" HorizontalAlignment="Stretch"
                                                  HorizontalContentAlignment="Stretch" IsExpanded="False"
                                                  Padding="0" MinHeight="0">
                                            <Expander.Header>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="&#x1F9E0;" FontSize="12"/>
                                                    <TextBlock Text="Reasoning" FontSize="12" FontStyle="Italic"
                                                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                                </StackPanel>
                                            </Expander.Header>
                                            <TextBlock Text="{x:Bind ThinkingContent, Mode=OneWay}" TextWrapping="WrapWholeWords"
                                                       FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"
                                                       FontStyle="Italic" Padding="8,4"/>
                                        </Expander>

                                        <TextBlock Text="{x:Bind Content, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Thinking indicator — uses Opacity to avoid layout shift -->
                <Border Grid.Row="2" x:Name="ThinkingIndicator" Opacity="0"
                        Padding="18,8" Background="Transparent" Height="36">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ProgressRing x:Name="ThinkingRing" IsActive="False" Width="16" Height="16"
                                          Foreground="{StaticResource AppAccentBrush}"/>
                            <TextBlock x:Name="ThinkingText" Text="Hermes is thinking..."
                                       FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"
                                       FontStyle="Italic"/>
                        </StackPanel>
                        <Button x:Name="StopButton" Content="Stop" Click="StopGeneration_Click"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="{StaticResource AppInsetBrush}" Foreground="White"
                                BorderBrush="{StaticResource AppSubtleStrokeBrush}"
                                Padding="12,4" FontSize="12" CornerRadius="6"/>
                    </Grid>
                </Border>

                <!-- Input Area — Claude Code style -->
                <StackPanel Grid.Row="3" Padding="18,8,18,14" Spacing="6">
                    <!-- Input container with rounded border -->
                    <Border Background="{StaticResource AppInsetBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="1" CornerRadius="12" Padding="12,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="PromptTextBox"
                                     AcceptsReturn="True"
                                     MaxHeight="200" MinHeight="36"
                                     PlaceholderText="Message Hermes..."
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     TextWrapping="Wrap"
                                     KeyDown="PromptTextBox_KeyDown"
                                     TextChanged="PromptTextBox_TextChanged" />

                            <Button x:Name="SendButton" Grid.Column="1"
                                    Click="SendPrompt_Click"
                                    VerticalAlignment="Bottom"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="8" CornerRadius="8"
                                    IsEnabled="False">
                                <FontIcon Glyph="&#xE724;" FontSize="18"
                                          Foreground="{StaticResource AppAccentBrush}" />
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Permission mode indicator + disclaimer -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6" Opacity="0.5">
                            <TextBlock x:Name="PermissionModeLabel" Text="Default mode"
                                       FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <HyperlinkButton x:Name="PermissionModeToggle" Content="change"
                                             FontSize="11" Padding="0"
                                             Click="PermissionModeToggle_Click" />
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="Hermes can make mistakes. Verify important information."
                                   FontSize="10" Foreground="{StaticResource AppTextSecondaryBrush}"
                                   Opacity="0.4" HorizontalAlignment="Right" VerticalAlignment="Center" />
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Splitter (drag to resize chat ↔ right panel) -->
        <Border Grid.Column="1" Grid.Row="1" Width="12" Background="Transparent" Margin="-3,0"
                PointerPressed="Splitter_PointerPressed" PointerMoved="Splitter_PointerMoved"
                PointerReleased="Splitter_PointerReleased" PointerEntered="Splitter_PointerEntered"
                PointerExited="Splitter_PointerExited">
            <Border x:Name="SplitterHandle" Width="4" Background="{StaticResource AppStrokeBrush}"
                    HorizontalAlignment="Center" CornerRadius="2" Opacity="0.5"/>
        </Border>

        <!-- Right Panel - Tabbed Panels -->
        <Border Grid.Column="2" Grid.Row="1" Style="{StaticResource SurfaceCardStyle}" Background="{StaticResource AppPaneBackgroundBrush}" Padding="0">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Tab selector -->
                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="8,8,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="TabSessions" Content="Sessions" Click="PanelTab_Click" Tag="sessions"
                                Background="Transparent" Foreground="{StaticResource AppAccentTextBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                        <Button x:Name="TabFiles" Content="Files" Click="PanelTab_Click" Tag="files"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                        <Button x:Name="TabTasks" Content="Tasks" Click="PanelTab_Click" Tag="tasks"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                        <Button x:Name="TabReplay" Content="Replay" Click="PanelTab_Click" Tag="replay"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Panel content area -->
                <Border Grid.Row="1" Padding="12,8">
                    <Grid>
                        <panels:SessionPanel x:Name="SessionPanelView" Visibility="Visible"/>
                        <panels:FileBrowserPanel x:Name="FileBrowserPanelView" Visibility="Collapsed"/>
                        <panels:TaskPanel x:Name="TaskPanelView" Visibility="Collapsed"/>
                        <panels:ReplayPanel x:Name="ReplayPanelView" Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Session info footer -->
                <Border Grid.Row="2" Padding="12,6" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="SessionIdLabel" FontSize="11"
                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
