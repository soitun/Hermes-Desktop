<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:HermesDesktop.Models"
    xmlns:panels="using:HermesDesktop.Views.Panels"
    Background="Transparent"
    Loaded="OnPageLoaded"
    NavigationCacheMode="Required"
    mc:Ignorable="d">
    <!-- Enter sends, Shift+Enter for newline (handled in KeyDown) -->

    <Grid x:Name="MainGrid" Padding="20,12,24,20" ColumnSpacing="14" RowSpacing="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="400"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="340" MinWidth="260" MaxWidth="500"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Grid.ColumnSpan="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="Hermes.C# - Your AI Teammate" FontSize="22" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="ConnectionStateText" Style="{StaticResource BodySecondaryTextStyle}" />
                    <TextBlock x:Name="CurrentModelText" FontSize="13"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               Text="" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="New Chat" Click="NewChat_Click" Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppSubtleStrokeBrush}" Foreground="White" />
            </StackPanel>
        </Grid>

        <!-- Main Chat Area -->
        <Border Grid.Row="1" Style="{StaticResource SurfaceCardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Messages -->
                <ListView x:Name="MessagesList" Grid.Row="1" Padding="18" Background="Transparent" BorderThickness="0"
                    ItemsSource="{x:Bind Messages, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ChatMessageItem">
                            <Grid Margin="0,0,0,10">
                                <Border MaxWidth="780" HorizontalAlignment="{x:Bind BubbleAlignment}"
                                    Background="{x:Bind BubbleBackground}" BorderBrush="{x:Bind BubbleBorderBrush}"
                                    BorderThickness="1" CornerRadius="12" Padding="16,12">
                                    <StackPanel Spacing="8">
                                        <TextBlock Foreground="{x:Bind LabelBrush}" Style="{StaticResource LabelTextStyle}" Text="{x:Bind AuthorLabel}" />
                                        <TextBlock Text="{x:Bind Content, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Thinking indicator — uses Opacity to avoid layout shift -->
                <Border Grid.Row="2" x:Name="ThinkingIndicator" Opacity="0"
                        Padding="18,8" Background="Transparent" Height="36">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ProgressRing x:Name="ThinkingRing" IsActive="False" Width="16" Height="16"
                                      Foreground="{StaticResource AppAccentBrush}"/>
                        <TextBlock x:Name="ThinkingText" Text="Hermes is thinking..."
                                   FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </Border>

                <!-- Input Area -->
                <Grid Grid.Row="3" Padding="18,14,18,18" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Permission Mode -->
                    <ComboBox x:Name="PermissionModeSelector" Grid.Row="0" Margin="0,0,0,10" HorizontalAlignment="Stretch"
                        SelectionChanged="PermissionModeSelector_SelectionChanged">
                        <ComboBoxItem Content="Default (Ask Everything)" Tag="Default" />
                        <ComboBoxItem Content="Plan Mode (Read-Only)" Tag="Plan" />
                        <ComboBoxItem Content="Auto Mode" Tag="Auto" />
                        <ComboBoxItem Content="Accept Edits" Tag="AcceptEdits" />
                        <ComboBoxItem Content="Bypass (DANGEROUS)" Tag="Bypass" />
                    </ComboBox>

                    <!-- Input -->
                    <Grid Grid.Row="1" ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PromptTextBox" Grid.Row="1" Grid.Column="0" MinHeight="88"
                            AcceptsReturn="False" KeyDown="PromptTextBox_KeyDown"
                            PlaceholderText="Type a message... (Enter to send, Shift+Enter for newline)"
                            Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppStrokeBrush}"
                            Foreground="White" TextWrapping="Wrap" />

                        <Button x:Name="SendButton" Grid.Column="1" Content="Send" Click="SendPrompt_Click"
                            Background="{StaticResource AppAccentGradientBrush}" BorderBrush="{StaticResource AppAccentDarkBrush}"
                            Foreground="#16110D" VerticalAlignment="Bottom" Padding="30,10" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- Splitter -->
        <Border Grid.Column="1" Grid.Row="1" Width="6" Background="Transparent"
                PointerPressed="Splitter_PointerPressed" PointerMoved="Splitter_PointerMoved" PointerReleased="Splitter_PointerReleased">
            <Border Width="2" Background="{StaticResource AppStrokeBrush}" HorizontalAlignment="Center" CornerRadius="1"/>
        </Border>

        <!-- Right Panel - Tabbed Panels -->
        <Border Grid.Column="2" Grid.Row="1" Style="{StaticResource SurfaceCardStyle}" Background="{StaticResource AppPaneBackgroundBrush}" Padding="0">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Tab selector -->
                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="8,8,8,0">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="TabSessions" Content="Sessions" Click="PanelTab_Click" Tag="sessions"
                                Background="Transparent" Foreground="{StaticResource AppAccentTextBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                        <Button x:Name="TabFiles" Content="Files" Click="PanelTab_Click" Tag="files"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                        <Button x:Name="TabSkills" Content="Skills" Click="PanelTab_Click" Tag="skills"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                        <Button x:Name="TabMemory" Content="Memory" Click="PanelTab_Click" Tag="memory"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                        <Button x:Name="TabTasks" Content="Tasks" Click="PanelTab_Click" Tag="tasks"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                        <Button x:Name="TabBuddy" Content="Buddy" Click="PanelTab_Click" Tag="buddy"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Panel content area -->
                <Border Grid.Row="1" Padding="12,8">
                    <Grid>
                        <panels:SessionPanel x:Name="SessionPanelView" Visibility="Visible"/>
                        <panels:FileBrowserPanel x:Name="FileBrowserPanelView" Visibility="Collapsed"/>
                        <panels:SkillsPanel x:Name="SkillsPanelView" Visibility="Collapsed"/>
                        <panels:MemoryPanel x:Name="MemoryPanelView" Visibility="Collapsed"/>
                        <panels:TaskPanel x:Name="TaskPanelView" Visibility="Collapsed"/>
                        <panels:BuddyPanel x:Name="BuddyPanelView" Visibility="Collapsed"/>
                    </Grid>
                </Border>

                <!-- Session info footer -->
                <Border Grid.Row="2" Padding="12,6" BorderBrush="{StaticResource AppStrokeBrush}" BorderThickness="0,1,0,0">
                    <TextBlock x:Name="SessionIdLabel" FontSize="11"
                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
