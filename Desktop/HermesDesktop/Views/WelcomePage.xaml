<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Padding="48,36,48,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="6">
            <TextBlock x:Name="EyebrowText" Text="Welcome" Style="{StaticResource PageEyebrowTextStyle}"/>
            <TextBlock x:Name="TitleText" Text="Welcome to Hermes Desktop"
                       FontSize="32" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock x:Name="SubtitleText"
                       Text="A native Windows agent that runs locally on your machine. Let's get you set up in two short steps."
                       FontSize="15" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap"
                       MaxWidth="760"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource SurfaceCardStyle}" Margin="0,24,0,0" MaxWidth="760"
                HorizontalAlignment="Left">
            <StackPanel Spacing="14">
                <TextBlock Text="What you get out of the box" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource AppAccentTextBrush}"/>
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                  Foreground="{StaticResource AppAccentTextBrush}" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Streaming chat with tool use" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Live token output, tool-progress chips, and per-session usage stats."
                                       FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE756;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                  Foreground="{StaticResource AppAccentTextBrush}" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="MCP, memory, and skills" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Bring your own MCP servers. Persistent memory and a skills library are already wired."
                                       FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                  Foreground="{StaticResource AppAccentTextBrush}" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Private by default" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Run a local model (LM Studio, Ollama, vLLM, llama.cpp) — or bring your own cloud key."
                                       FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,24,0,0">
            <Button x:Name="GetStartedButton" Content="Get started"
                    Click="GetStarted_Click"
                    Background="{StaticResource AppAccentBrush}" Foreground="#16110D" Padding="22,10" FontWeight="SemiBold"/>
            <Button x:Name="SkipButton" Content="Skip setup"
                    Click="Skip_Click"
                    Background="{StaticResource AppInsetBrush}" Padding="22,10"/>
        </StackPanel>
    </Grid>
</Page>
