<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HermesDesktop.Views.Panels.ReplayPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:HermesDesktop.Models">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header: Title + Record toggle + Play button -->
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Activity" Style="{StaticResource SectionTitleTextStyle}"/>
            <ToggleButton x:Name="RecordToggle" Click="RecordToggle_Click"
                          AutomationProperties.Name="Record activity"
                          Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}"
                          CornerRadius="6" Padding="8,4" MinWidth="0" FontSize="11">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Ellipse x:Name="RecordDot" Width="8" Height="8" Fill="Gray"/>
                    <TextBlock x:Name="RecordLabel" Text="Record" FontSize="11"/>
                </StackPanel>
            </ToggleButton>
            <Button x:Name="PlayBtn" Content="&#x25B6; Play" Click="PlayBtn_Click"
                    AutomationProperties.Name="Play replay"
                    Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}"
                    CornerRadius="6" Padding="8,4" MinWidth="0" FontSize="11"/>
            <Button x:Name="ClearBtn" Content="Clear" Click="ClearBtn_Click"
                    AutomationProperties.Name="Clear replay"
                    Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}"
                    CornerRadius="6" Padding="8,4" MinWidth="0" FontSize="11"/>
        </StackPanel>

        <!-- Empty state -->
        <TextBlock Grid.Row="1" x:Name="EmptyState" Visibility="Visible"
                   Text="No activity yet.&#x0a;Send a message to see the agent work."
                   Foreground="{StaticResource AppTextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" FontSize="13" Opacity="0.7"/>

        <!-- Activity list -->
        <ListView Grid.Row="1" x:Name="ActivityList" Background="Transparent"
                  SelectionMode="None" IsItemClickEnabled="True" ItemClick="ActivityList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ActivityDisplayItem">
                    <Grid Margin="0,2" Padding="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Main row -->
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" Background="{x:Bind HighlightBackground, Mode=OneWay}">
                            <!-- Status dot -->
                            <TextBlock Grid.Column="0" Text="{x:Bind StatusIcon, Mode=OneWay}"
                                       Foreground="{x:Bind StatusColor, Mode=OneWay}"
                                       FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>

                            <!-- Tool name + time + input summary -->
                            <StackPanel Grid.Column="1" Spacing="1">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{x:Bind ToolName}" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource AppAccentTextBrush}"/>
                                    <TextBlock Text="{x:Bind FormattedTime}" FontSize="10"
                                               Foreground="{StaticResource AppTextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind InputSummary}" FontSize="10"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" MaxLines="1"/>
                            </StackPanel>

                            <!-- Duration badge -->
                            <Border Grid.Column="2" Background="{x:Bind DurationColor, Mode=OneWay}"
                                    CornerRadius="4" Padding="5,1" Margin="4,0"
                                    VerticalAlignment="Center" Opacity="0.85">
                                <TextBlock Text="{x:Bind DurationText, Mode=OneWay}" FontSize="9" Foreground="White"/>
                            </Border>
                        </Grid>

                        <!-- Expanded detail (toggled) -->
                        <StackPanel Grid.Row="1" Spacing="6" Margin="18,6,0,4"
                                    Visibility="{x:Bind IsExpanded, Mode=OneWay}">
                            <!-- Input args -->
                            <!-- Each detail block uses a constrained-height ScrollViewer instead of
                                 TextBlock.MaxLines: MaxLines visually truncates so text past the cap
                                 is unreachable for selection / Ctrl-C, defeating the copy-paste fix.
                                 ScrollViewer keeps the row size bounded but lets the user scroll AND
                                 select the entire output. -->
                            <StackPanel Spacing="2">
                                <TextBlock Text="Input" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <Border Background="{StaticResource AppInsetBrush}" CornerRadius="4" Padding="8,6">
                                    <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock Text="{x:Bind InputFull}" FontSize="10"
                                                   FontFamily="Cascadia Mono, Consolas" TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                                   IsTextSelectionEnabled="True"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>

                            <!-- Output -->
                            <StackPanel Spacing="2">
                                <TextBlock Text="Output" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <Border Background="{StaticResource AppInsetBrush}" CornerRadius="4" Padding="8,6">
                                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock Text="{x:Bind OutputFull, Mode=OneWay}" FontSize="10"
                                                   FontFamily="Cascadia Mono, Consolas" TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                                   IsTextSelectionEnabled="True"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>

                            <!-- Diff preview (if present) -->
                            <StackPanel Spacing="2" Visibility="{x:Bind HasDiff, Mode=OneWay}">
                                <TextBlock Text="Diff" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <Border Background="{StaticResource AppInsetBrush}" CornerRadius="4" Padding="8,6">
                                    <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <TextBlock Text="{x:Bind DiffPreview, Mode=OneWay}" FontSize="10"
                                                   FontFamily="Cascadia Mono, Consolas" TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppAccentTextBrush}"
                                                   IsTextSelectionEnabled="True"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>

                            <!-- Screenshot thumbnail (if present) -->
                            <StackPanel Spacing="2" Visibility="{x:Bind HasScreenshot, Mode=OneWay}">
                                <TextBlock Text="Screenshot" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <Image x:Name="ScreenshotImage" MaxHeight="160" Stretch="Uniform"
                                       HorizontalAlignment="Left"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Screenshot preview area (for playback) -->
        <Border Grid.Row="2" x:Name="PreviewArea" Visibility="Collapsed"
                Background="{StaticResource AppInsetBrush}" CornerRadius="6"
                Padding="4" Margin="0,4,0,0" MaxHeight="180">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>
        </Border>
    </Grid>
</UserControl>
