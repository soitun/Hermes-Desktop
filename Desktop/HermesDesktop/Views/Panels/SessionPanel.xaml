<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HermesDesktop.Views.Panels.SessionPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="Auto,Auto,*">
        <TextBlock Text="Sessions" Style="{StaticResource SectionTitleTextStyle}" Margin="0,0,0,8"/>

        <Grid Grid.Row="1" ColumnSpacing="8" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox"
                     AutomationProperties.Name="Search sessions"
                     PlaceholderText="Search sessions..."
                     FontSize="12"
                     Style="{StaticResource AppTextBoxStyle}"
                     TextChanged="SearchBox_TextChanged"/>
            <Button x:Name="NewSessionBtn"
                    Grid.Column="1"
                    AutomationProperties.Name="New session"
                    Click="NewSession_Click"
                    Style="{StaticResource IconButtonStyle}"
                    Background="{StaticResource AppAccentGradientBrush}"
                    BorderBrush="{StaticResource AppAccentDarkBrush}"
                    Foreground="{StaticResource AppOnAccentTextBrush}"
                    ToolTipService.ToolTip="New session">
                <FontIcon Glyph="&#xE710;" FontSize="12" />
            </Button>
            <Button x:Name="ClearChatsBtn"
                    Grid.Column="2"
                    AutomationProperties.Name="Clear all chats"
                    Click="ClearChats_Click"
                    Style="{StaticResource IconButtonStyle}"
                    BorderBrush="{StaticResource StatusErrorBrush}"
                    Foreground="{StaticResource StatusErrorBrush}"
                    ToolTipService.ToolTip="Clear all chats">
                <FontIcon Glyph="&#xE74D;" FontSize="12" />
            </Button>
        </Grid>

        <TextBlock Grid.Row="2" x:Name="EmptyState" Visibility="Collapsed"
                   Text="No conversations yet.&#x0a;Start chatting to create your first session."
                   Foreground="{StaticResource AppTextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" FontSize="13" Opacity="0.7"/>

        <ListView Grid.Row="2" x:Name="SessionList" SelectionChanged="SessionList_SelectionChanged"
                  Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4" Padding="6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource AppAccentTextBrush}" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding TimeAgo}" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{Binding MessageCount}" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Content="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                AutomationProperties.Name="Delete session"
                                Click="DeleteSession_Click" Tag="{Binding Id}"
                                Style="{StaticResource IconButtonStyle}"
                                BorderThickness="0" Padding="6,4" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Delete session"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
