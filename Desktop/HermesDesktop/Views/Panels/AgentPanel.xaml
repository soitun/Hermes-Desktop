<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HermesDesktop.Views.Panels.AgentPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">
        <!-- Sub-tab selector -->
        <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,8">
            <Button x:Name="TabIdentity" Content="Identity" Click="SubTab_Click" Tag="identity"
                    Background="Transparent" Foreground="{StaticResource AppAccentTextBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
            <Button x:Name="TabSouls" Content="Souls" Click="SubTab_Click" Tag="souls"
                    Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
            <Button x:Name="TabAgents" Content="Agents" Click="SubTab_Click" Tag="agents"
                    Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" Padding="8,4" CornerRadius="6" MinWidth="0"/>
        </StackPanel>

        <!-- ═══ Identity Tab ═══ -->
        <ScrollViewer x:Name="IdentityContent" Grid.Row="1" Visibility="Visible">
            <StackPanel Spacing="12" Padding="0,4">
                <!-- Active soul indicator -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Active:" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <TextBlock x:Name="ActiveSoulLabel" Text="Default" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentTextBrush}"/>
                </StackPanel>

                <!-- SOUL.md editor -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Soul (SOUL.md)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentTextBrush}"/>
                    <TextBox x:Name="SoulEditor" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="140" MaxHeight="220" FontSize="12" FontFamily="Consolas"
                             Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppStrokeBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Save" Click="SaveSoul_Click" FontSize="11" Padding="12,4"
                                Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D"/>
                        <Button Content="Reset" Click="ResetSoul_Click" FontSize="11" Padding="12,4"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}"
                                BorderBrush="{StaticResource AppStrokeBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- USER.md editor -->
                <StackPanel Spacing="4">
                    <TextBlock Text="User Profile (USER.md)" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentTextBrush}"/>
                    <TextBox x:Name="UserEditor" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="100" MaxHeight="180" FontSize="12" FontFamily="Consolas"
                             Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppStrokeBrush}"/>
                    <Button Content="Save Profile" Click="SaveUser_Click" FontSize="11" Padding="12,4"
                            Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D"/>
                </StackPanel>

                <!-- Mistakes + Habits -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Learned Mistakes" FontSize="12" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                    <ListView x:Name="MistakesList" Background="Transparent" SelectionMode="None" MaxHeight="100">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" Margin="0,1"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Good Habits" FontSize="12" FontWeight="SemiBold" Foreground="#6BCB77"/>
                    <ListView x:Name="HabitsList" Background="Transparent" SelectionMode="None" MaxHeight="100">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" Margin="0,1"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Souls Browser Tab ═══ -->
        <Grid x:Name="SoulsContent" Grid.Row="1" Visibility="Collapsed" RowDefinitions="*,Auto,Auto">
            <!-- Soul list -->
            <ListView x:Name="SoulsList" Background="Transparent" SelectionChanged="SoulsList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource AppAccentTextBrush}"/>
                                <TextBlock Text="{Binding Description}" FontSize="11" TextWrapping="Wrap"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" MaxLines="2"/>
                                <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,0">
                                    <Border Background="#3A3A00" CornerRadius="4" Padding="6,1">
                                        <TextBlock Text="{Binding Category}" FontSize="9" Foreground="{StaticResource AppAccentTextBrush}"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Preview -->
            <Border Grid.Row="1" Style="{StaticResource InsetCardStyle}" MaxHeight="150" Margin="0,6,0,0"
                    x:Name="SoulPreviewBorder" Visibility="Collapsed">
                <ScrollViewer>
                    <TextBlock x:Name="SoulPreviewText" FontSize="11" FontFamily="Consolas" TextWrapping="Wrap"
                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                </ScrollViewer>
            </Border>

            <!-- Action buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                <Button x:Name="ApplySoulBtn" Content="Apply Soul" Click="ApplySoul_Click" FontSize="11" Padding="12,4"
                        Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D" IsEnabled="False"/>
                <Button x:Name="CustomizeSoulBtn" Content="Customize" Click="CustomizeSoul_Click" FontSize="11" Padding="12,4"
                        Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}"
                        BorderBrush="{StaticResource AppStrokeBrush}" IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <!-- ═══ Agents Tab ═══ -->
        <Grid x:Name="AgentsContent" Grid.Row="1" Visibility="Collapsed" RowDefinitions="Auto,*,Auto">
            <Button Content="+ New Agent" Click="NewAgent_Click" FontSize="11" Padding="12,4" HorizontalAlignment="Right"
                    Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D" Margin="0,0,0,6"/>

            <ListView Grid.Row="1" x:Name="AgentsList" Background="Transparent" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,4" ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource AppAccentTextBrush}"/>
                                    <Border x:Name="ActiveBadge" Background="#3A3A00" CornerRadius="4" Padding="6,1"
                                            Visibility="{Binding ActiveVisibility}">
                                        <TextBlock Text="active" FontSize="9" Foreground="{StaticResource AppAccentTextBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" FontSize="11"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <Button Content="Use" Tag="{Binding Name}" Click="ActivateAgent_Click" FontSize="10" Padding="8,2"
                                        Background="Transparent" Foreground="{StaticResource AppAccentTextBrush}"
                                        BorderBrush="{StaticResource AppStrokeBrush}"/>
                                <Button Content="X" Tag="{Binding Name}" Click="DeleteAgent_Click" FontSize="10" Padding="6,2"
                                        Background="Transparent" Foreground="#FF6B6B" BorderBrush="Transparent"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="2" x:Name="NoAgentsText"
                       Text="No custom agents yet. Create one to save a soul + model configuration."
                       FontSize="11" Opacity="0.5" Foreground="{StaticResource AppTextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,4"/>
        </Grid>
    </Grid>
</UserControl>
