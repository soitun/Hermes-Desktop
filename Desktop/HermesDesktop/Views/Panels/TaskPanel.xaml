<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HermesDesktop.Views.Panels.TaskPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <TextBlock Text="Tasks" Style="{StaticResource SectionTitleTextStyle}"/>
            <Button x:Name="RefreshBtn" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                    AutomationProperties.Name="Refresh tasks"
                    ToolTipService.ToolTip="Refresh tasks"
                    Click="Refresh_Click" CornerRadius="6" Padding="6,2"
                    Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}"/>
        </StackPanel>

        <TextBlock Grid.Row="1" x:Name="EmptyState" Visibility="Collapsed"
                   Text="No tasks yet.&#x0a;Tasks are created by the agent during work."
                   Foreground="{StaticResource AppTextSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" FontSize="13" Opacity="0.7"/>

        <ListView Grid.Row="1" x:Name="TaskList" Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4">
                        <Border Grid.Column="0" Background="{Binding StatusColor}" CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Description}" FontSize="13"
                                       Foreground="{Binding DescriptionBrush}" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding PriorityLabel}" FontSize="11"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <TextBlock Text="{Binding DueLabel}" FontSize="11"
                                           Foreground="{Binding DueBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>
