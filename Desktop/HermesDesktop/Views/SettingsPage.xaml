<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d"
    NavigationCacheMode="Required">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,24,32,40" Spacing="20">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="14">
                    <TextBlock
                        x:Uid="SettingsEyebrow"
                        Style="{StaticResource PageEyebrowTextStyle}" />
                    <TextBlock
                        x:Uid="SettingsTitle"
                        Style="{StaticResource PageTitleTextStyle}"
                        MaxWidth="920" />
                    <TextBlock
                        x:Uid="SettingsSubtitle"
                        Style="{StaticResource BodySecondaryTextStyle}"
                        MaxWidth="920" />
                </StackPanel>
            </Border>

            <!-- Editable Model Configuration -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            x:Uid="SettingsRuntimeTitle"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <StackPanel Spacing="12">
                            <!-- Provider -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="PROVIDER" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="ProviderCombo" HorizontalAlignment="Stretch"
                                          Background="{StaticResource AppInsetBrush}"
                                          BorderBrush="{StaticResource AppStrokeBrush}"
                                          SelectionChanged="ProviderCombo_SelectionChanged">
                                    <ComboBoxItem Content="Nous (OpenRouter)" Tag="nous"/>
                                    <ComboBoxItem Content="OpenAI" Tag="openai"/>
                                    <ComboBoxItem Content="Anthropic" Tag="anthropic"/>
                                    <ComboBoxItem Content="Qwen (Alibaba)" Tag="qwen"/>
                                    <ComboBoxItem Content="DeepSeek" Tag="deepseek"/>
                                    <ComboBoxItem Content="MiniMax" Tag="minimax"/>
                                    <ComboBoxItem Content="OpenRouter" Tag="openrouter"/>
                                    <ComboBoxItem Content="Custom / Local" Tag="local"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Base URL -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="BASE URL" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="BaseUrlBox" PlaceholderText="http://127.0.0.1:11434/v1"
                                         Background="{StaticResource AppInsetBrush}"
                                         BorderBrush="{StaticResource AppStrokeBrush}"
                                         Foreground="White"/>
                            </StackPanel>

                            <!-- Model Picker -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="MODEL" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="ModelCombo" HorizontalAlignment="Stretch"
                                          Background="{StaticResource AppInsetBrush}"
                                          BorderBrush="{StaticResource AppStrokeBrush}"
                                          SelectionChanged="ModelCombo_SelectionChanged"/>
                                <TextBox x:Name="ModelBox" PlaceholderText="Or type a custom model ID"
                                         Background="{StaticResource AppInsetBrush}"
                                         BorderBrush="{StaticResource AppStrokeBrush}"
                                         Foreground="White"/>
                                <TextBlock x:Name="ContextLengthLabel" FontSize="12"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           Text="Context: --"/>
                            </StackPanel>

                            <!-- API Key -->
                            <StackPanel Spacing="4">
                                <TextBlock Text="API KEY" Style="{StaticResource LabelTextStyle}"/>
                                <PasswordBox x:Name="ApiKeyBox" PlaceholderText="sk-... (leave blank for local)"
                                             Background="{StaticResource AppInsetBrush}"
                                             BorderBrush="{StaticResource AppStrokeBrush}"
                                             Foreground="White"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="AUTH MODE" Style="{StaticResource LabelTextStyle}"/>
                                <ComboBox x:Name="AuthModeCombo" HorizontalAlignment="Stretch"
                                          Background="{StaticResource AppInsetBrush}"
                                          BorderBrush="{StaticResource AppStrokeBrush}"
                                          SelectionChanged="AuthModeCombo_SelectionChanged">
                                    <ComboBoxItem Content="API Key" Tag="api_key"/>
                                    <ComboBoxItem Content="OAuth Proxy (Env Token)" Tag="oauth_proxy_env"/>
                                    <ComboBoxItem Content="OAuth Proxy (Command Token)" Tag="oauth_proxy_command"/>
                                    <ComboBoxItem Content="No Auth Header" Tag="none"/>
                                </ComboBox>
                            </StackPanel>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="AUTH HEADER" Style="{StaticResource LabelTextStyle}"/>
                                    <TextBox x:Name="AuthHeaderBox" PlaceholderText="Authorization"
                                             Background="{StaticResource AppInsetBrush}"
                                             BorderBrush="{StaticResource AppStrokeBrush}"
                                             Foreground="White"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="AUTH SCHEME" Style="{StaticResource LabelTextStyle}"/>
                                    <TextBox x:Name="AuthSchemeBox" PlaceholderText="Bearer"
                                             Background="{StaticResource AppInsetBrush}"
                                             BorderBrush="{StaticResource AppStrokeBrush}"
                                             Foreground="White"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock Text="TOKEN ENV VAR" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="AuthTokenEnvBox" PlaceholderText="OPENAI_OAUTH_ACCESS_TOKEN"
                                         Background="{StaticResource AppInsetBrush}"
                                         BorderBrush="{StaticResource AppStrokeBrush}"
                                         Foreground="White"/>
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Text="TOKEN COMMAND" Style="{StaticResource LabelTextStyle}"/>
                                <TextBox x:Name="AuthTokenCommandBox" PlaceholderText="oauth-proxy-helper print-access-token"
                                         Background="{StaticResource AppInsetBrush}"
                                         BorderBrush="{StaticResource AppStrokeBrush}"
                                         Foreground="White"/>
                            </StackPanel>

                            <TextBlock Text="OAuth proxy modes let Hermes fetch a short-lived token from an environment variable or refresh command and attach it to an OpenAI-compatible proxy request."
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"
                                       FontSize="12"/>

                            <!-- Save + Feedback -->
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button x:Name="SaveModelBtn" Content="Save Model Config" Click="SaveModelConfig_Click"
                                        Background="{StaticResource AppAccentGradientBrush}"
                                        BorderBrush="{StaticResource AppAccentDarkBrush}"
                                        Foreground="#16110D" Padding="20,8"/>
                                <TextBlock x:Name="ModelSaveStatus" VerticalAlignment="Center"
                                           Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock
                            x:Uid="SettingsGatewayTitle"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <Grid ColumnSpacing="18" RowSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                x:Uid="SettingsGatewayLine1"
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                Text="{x:Bind TelegramStatus, Mode=OneTime}" />

                            <TextBlock
                                x:Uid="SettingsGatewayLine2"
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="1"
                                Text="{x:Bind DiscordStatus, Mode=OneTime}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock
                        x:Uid="SettingsPathsTitle"
                        Style="{StaticResource SectionTitleTextStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            x:Uid="SettingsHomeButton"
                            AccessKey="H"
                            AutomationProperties.AutomationId="SettingsHomeButton"
                            Background="{StaticResource AppInsetBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            Click="OpenHome_Click"
                            Foreground="White" />
                        <Button
                            x:Uid="SettingsConfigButton"
                            AccessKey="C"
                            AutomationProperties.AutomationId="SettingsConfigButton"
                            Background="{StaticResource AppInsetBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            Click="OpenConfig_Click"
                            Foreground="White" />
                        <Button
                            x:Uid="SettingsLogsButton"
                            AccessKey="G"
                            AutomationProperties.AutomationId="SettingsLogsButton"
                            Background="{StaticResource AppInsetBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            Click="OpenLogs_Click"
                            Foreground="White" />
                        <Button
                            x:Uid="SettingsWorkspaceButton"
                            AccessKey="R"
                            AutomationProperties.AutomationId="SettingsWorkspaceButton"
                            Background="{StaticResource AppInsetBrush}"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            Click="OpenWorkspace_Click"
                            Foreground="White" />
                    </StackPanel>
                    <Grid ColumnSpacing="18" RowSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            x:Uid="DashboardHermesHomeLabel"
                            Grid.Row="0"
                            Grid.Column="0"
                            Style="{StaticResource LabelTextStyle}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Text="{x:Bind HermesHomePath, Mode=OneTime}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            x:Uid="DashboardConfigLabel"
                            Grid.Row="1"
                            Grid.Column="0"
                            Style="{StaticResource LabelTextStyle}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Text="{x:Bind HermesConfigPath, Mode=OneTime}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            x:Uid="DashboardLogsLabel"
                            Grid.Row="2"
                            Grid.Column="0"
                            Style="{StaticResource LabelTextStyle}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Text="{x:Bind HermesLogsPath, Mode=OneTime}"
                            TextWrapping="Wrap" />

                        <TextBlock
                            x:Uid="DashboardWorkspaceLabel"
                            Grid.Row="3"
                            Grid.Column="0"
                            Style="{StaticResource LabelTextStyle}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Text="{x:Bind HermesWorkspacePath, Mode=OneTime}"
                            TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
