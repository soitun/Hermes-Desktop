<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.DiagnosticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Disabled"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar
            x:Name="StatusInfoBar"
            Grid.Row="0"
            Margin="0,0,0,12"
            IsClosable="True"
            IsOpen="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="20" MaxWidth="960">
                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="DiagnosticsPageEyebrow" Style="{StaticResource PageEyebrowTextStyle}" />
                        <TextBlock x:Uid="DiagnosticsPageTitle" Style="{StaticResource PageTitleTextStyle}" MaxWidth="920" />
                        <TextBlock
                            x:Uid="DiagnosticsPageIntro"
                            Style="{StaticResource BodySecondaryTextStyle}"
                            MaxWidth="920"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Uid="DiagnosticsSummarySectionTitle" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            x:Name="SummaryBody"
                            FontSize="13"
                            Foreground="{StaticResource AppTextPrimaryBrush}"
                            IsTextSelectionEnabled="True"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button
                        x:Uid="DiagnosticsCopyButton"
                        Click="CopyDiagnostics_Click"
                        Background="{StaticResource AppAccentGradientBrush}"
                        BorderBrush="{StaticResource AppOutlineBrush}"
                        Foreground="#16110D"
                        Padding="16,8" />
                    <Button
                        x:Uid="DiagnosticsOpenLogFolderButton"
                        Click="OpenLogFolder_Click"
                        Background="{StaticResource AppInsetBrush}"
                        BorderBrush="{StaticResource AppStrokeBrush}"
                        Foreground="{StaticResource AppTextPrimaryBrush}"
                        Padding="16,8" />
                    <Button
                        x:Uid="DiagnosticsReloadTailButton"
                        Click="ReloadTail_Click"
                        Background="{StaticResource AppInsetBrush}"
                        BorderBrush="{StaticResource AppStrokeBrush}"
                        Foreground="{StaticResource AppTextPrimaryBrush}"
                        Padding="16,8" />
                </StackPanel>

                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="DiagnosticsTailSectionTitle" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock
                            x:Uid="DiagnosticsTailHint"
                            FontSize="12"
                            Foreground="{StaticResource AppTextSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <ScrollViewer
                            MaxHeight="320"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto">
                            <TextBlock
                                x:Name="TailText"
                                FontFamily="Consolas"
                                FontSize="11"
                                Foreground="{StaticResource AppTextSecondaryBrush}"
                                IsTextSelectionEnabled="True"
                                TextWrapping="Wrap" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
