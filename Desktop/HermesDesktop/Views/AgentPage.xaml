<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.AgentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Spacing="4" Margin="0,0,0,16">
            <TextBlock Text="Agent Configuration" Style="{StaticResource PageEyebrowTextStyle}"/>
            <TextBlock Text="Identity, Souls, and Agent Profiles" FontSize="22" FontWeight="SemiBold"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Active:" FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                <TextBlock x:Name="ActiveSoulLabel" Text="Default" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource AppAccentTextBrush}"/>
            </StackPanel>
        </StackPanel>

        <!-- Tab bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,0,0,16">
            <Button x:Name="TabAgents" Content="Agents" Click="Tab_Click" Tag="agents"
                    Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D" FontSize="13" Padding="16,8" CornerRadius="8"/>
            <Button x:Name="TabIdentity" Content="Identity" Click="Tab_Click" Tag="identity"
                    Background="{StaticResource AppInsetBrush}" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="13" Padding="16,8" CornerRadius="8"
                    BorderBrush="{StaticResource AppStrokeBrush}"/>
            <Button x:Name="TabSouls" Content="Souls" Click="Tab_Click" Tag="souls"
                    Background="{StaticResource AppInsetBrush}" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="13" Padding="16,8" CornerRadius="8"
                    BorderBrush="{StaticResource AppStrokeBrush}"/>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- IDENTITY TAB                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <ScrollViewer x:Name="IdentityContent" Grid.Row="2" Visibility="Collapsed">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Soul editor -->
                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Soul Document (SOUL.md)" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AppAccentTextBrush}"/>
                        <TextBlock Text="Defines who your agent is — personality, values, working style."
                                   FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <TextBox x:Name="SoulEditor" AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="300" MaxHeight="500" FontSize="12" FontFamily="Consolas"
                                 Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppStrokeBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Save Soul" Click="SaveSoul_Click" FontSize="12" Padding="16,8"
                                    Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D"/>
                            <Button Content="Reset to Default" Click="ResetSoul_Click" FontSize="12" Padding="16,8"
                                    Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Right: User profile + journals -->
                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Text="User Profile (USER.md)" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource AppAccentTextBrush}"/>
                            <TextBlock Text="Tell your agent about you — expertise, preferences, how you work."
                                       FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBox x:Name="UserEditor" AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="180" MaxHeight="300" FontSize="12" FontFamily="Consolas"
                                     Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppStrokeBrush}"/>
                            <Button Content="Save Profile" Click="SaveUser_Click" FontSize="12" Padding="16,8"
                                    Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D"/>
                        </StackPanel>
                    </Border>

                    <!-- Learned journals -->
                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Learned from Mistakes" FontSize="14" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                            <ListView x:Name="MistakesList" Background="Transparent" SelectionMode="None" MaxHeight="120">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}" Margin="0,1"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock x:Name="NoMistakes" Text="No mistakes recorded yet." FontSize="11" Opacity="0.5"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Good Habits" FontSize="14" FontWeight="SemiBold" Foreground="#6BCB77"/>
                            <ListView x:Name="HabitsList" Background="Transparent" SelectionMode="None" MaxHeight="120">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="11" TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}" Margin="0,1"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <TextBlock x:Name="NoHabits" Text="No habits recorded yet." FontSize="11" Opacity="0.5"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- SOULS BROWSER TAB                               -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid x:Name="SoulsContent" Grid.Row="2" Visibility="Collapsed" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" MinWidth="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Soul list -->
            <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Text="Available Souls" FontSize="16" FontWeight="SemiBold" Margin="16,12"
                               Foreground="{StaticResource AppAccentTextBrush}"/>
                    <ListView Grid.Row="1" x:Name="SoulsList" Background="Transparent" Padding="8"
                              SelectionChanged="SoulsList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,6">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource AppAccentTextBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                               Foreground="{StaticResource AppTextSecondaryBrush}" MaxLines="2"/>
                                    <Border Background="#3A3A00" CornerRadius="4" Padding="8,2" Margin="0,4,0,0"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Category}" FontSize="10"
                                                   Foreground="{StaticResource AppAccentTextBrush}"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Right: Preview + actions -->
            <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock x:Name="SoulPreviewTitle" Text="Select a soul to preview" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentTextBrush}" Margin="0,0,0,8"/>
                    <ScrollViewer Grid.Row="1">
                        <TextBlock x:Name="SoulPreviewText" FontSize="13" FontFamily="Consolas" TextWrapping="Wrap"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                   Text="Click a soul from the list to see its full content here."/>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,12,0,0">
                        <Button x:Name="ApplySoulBtn" Content="Apply This Soul" Click="ApplySoul_Click"
                                FontSize="13" Padding="20,10" IsEnabled="False"
                                Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D"/>
                        <Button x:Name="CustomizeSoulBtn" Content="Copy to Editor" Click="CustomizeSoul_Click"
                                FontSize="13" Padding="20,10" IsEnabled="False"
                                Background="Transparent" Foreground="{StaticResource AppTextSecondaryBrush}"
                                BorderBrush="{StaticResource AppStrokeBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- AGENTS TAB                                      -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid x:Name="AgentsContent" Grid.Row="2" Visibility="Visible" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Agent list -->
            <Border Style="{StaticResource SurfaceCardStyle}">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,8">
                        <TextBlock Text="Saved Agents" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource AppAccentTextBrush}"/>
                        <Button Content="+ New Agent" Click="NewAgent_Click" FontSize="12" Padding="12,6"
                                Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D"
                                VerticalAlignment="Center"/>
                    </StackPanel>

                    <ListView Grid.Row="1" x:Name="AgentsList" Background="Transparent" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,6" ColumnDefinitions="*,Auto">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AppAccentTextBrush}"/>
                                            <Border Background="#3A3A00" CornerRadius="4" Padding="6,1"
                                                    Visibility="{Binding ActiveVisibility}">
                                                <TextBlock Text="active" FontSize="9" Foreground="{StaticResource AppAccentTextBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Button Content="Activate" Tag="{Binding Name}" Click="ActivateAgent_Click"
                                                FontSize="11" Padding="10,4"
                                                Background="Transparent" Foreground="{StaticResource AppAccentTextBrush}"
                                                BorderBrush="{StaticResource AppStrokeBrush}"/>
                                        <Button Content="Delete" Tag="{Binding Name}" Click="DeleteAgent_Click"
                                                FontSize="11" Padding="10,4"
                                                Background="Transparent" Foreground="#FF6B6B" BorderBrush="Transparent"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock Grid.Row="2" x:Name="NoAgentsText"
                               Text="No custom agents yet. Create one to save a soul + model configuration you can switch between."
                               FontSize="12" Opacity="0.5" Foreground="{StaticResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,8"/>
                </Grid>
            </Border>

            <!-- Right: Info -->
            <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="About Agents" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource AppAccentTextBrush}"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"
                               Text="Each agent is a saved configuration — a soul document paired with a name and description. Create different agents for different tasks:"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}" Opacity="0.8"
                               Text="  - A 'Code Reviewer' with the security-analyst soul&#x0a;  - A 'Writing Partner' with the creative soul&#x0a;  - A 'Teacher' for explaining concepts step by step&#x0a;  - A 'CTO' for quick pragmatic decisions"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"
                               Text="When you activate an agent, its soul is loaded into the system prompt. The agent remembers its identity across sessions through SOUL.md on disk."/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
