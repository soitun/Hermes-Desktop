<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="HermesDesktop.Views.Controls.ApprovalCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{StaticResource AppInsetBrush}"
            BorderBrush="{StaticResource StatusErrorBrush}" BorderThickness="1"
            CornerRadius="10" Padding="14" Margin="0,4">
        <StackPanel>
            <TextBlock Text="Shell Command Approval" FontWeight="SemiBold" FontSize="13"
                       Foreground="{StaticResource StatusErrorBrush}" Margin="0,0,0,6"/>
            <Border Background="{StaticResource AppWindowBackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                <TextBlock x:Name="CommandText" FontFamily="Cascadia Mono, Consolas" FontSize="12"
                           Foreground="{StaticResource AppAccentBrush}" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
            </Border>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="AllowOnceBtn" Content="Allow Once" Click="AllowOnce_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Background="#1F3A1F" Foreground="{StaticResource StatusSuccessBrush}"
                        Padding="{StaticResource ButtonPaddingCompact}"/>
                <Button x:Name="AllowSessionBtn" Content="Allow Session" Click="AllowSession_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Background="#1A2B3A" Foreground="{StaticResource StatusInfoBrush}"
                        Padding="{StaticResource ButtonPaddingCompact}"/>
                <Button x:Name="AlwaysAllowBtn" Content="Always Allow" Click="AlwaysAllow_Click"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Background="#332A0F" Foreground="{StaticResource AppAccentTextBrush}"
                        Padding="{StaticResource ButtonPaddingCompact}"/>
                <Button x:Name="DenyBtn" Content="Deny" Click="Deny_Click"
                        Style="{StaticResource DangerButtonStyle}"
                        Padding="{StaticResource ButtonPaddingCompact}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
