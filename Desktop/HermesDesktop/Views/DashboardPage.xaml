<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    Loaded="OnPageLoaded"
    mc:Ignorable="d"
    NavigationCacheMode="Required">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,24,32,40" Spacing="20">

            <!-- ═══ KPI Stats Row ═══ -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sessions -->
                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="DashOverviewKpiSessionsTitle" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <TextBlock x:Name="SessionCountText" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AppAccentTextBrush}"/>
                        <TextBlock x:Uid="DashOverviewKpiSessionsSub" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Opacity="0.6"/>
                    </StackPanel>
                </Border>

                <!-- Tools -->
                <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="DashOverviewKpiToolsTitle" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <TextBlock x:Name="ToolCountText" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="#6BCB77"/>
                        <TextBlock x:Uid="DashOverviewKpiToolsSub" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Opacity="0.6"/>
                    </StackPanel>
                </Border>

                <!-- Skills -->
                <Border Grid.Column="2" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="DashOverviewKpiSkillsTitle" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <TextBlock x:Name="SkillCountText" Text="0" FontSize="28" FontWeight="Bold"
                                   Foreground="#818CF8"/>
                        <TextBlock x:Uid="DashOverviewKpiSkillsSub" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Opacity="0.6"/>
                    </StackPanel>
                </Border>

                <!-- LLM Status -->
                <Border Grid.Column="3" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="DashOverviewKpiLlmTitle" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse x:Name="LlmStatusDot" Width="10" Height="10" Fill="#6BCB77" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LlmStatusText" x:Uid="DashOverviewLlmStatusInitial" FontSize="20" FontWeight="Bold"/>
                        </StackPanel>
                        <TextBlock x:Name="LlmModelText" Text="" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}" Opacity="0.6"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Dreamer status -->
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock x:Uid="DashDreamerCardTitle" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="DreamerPhaseText" x:Uid="DashDreamerPhaseInitial" FontSize="13"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               AutomationProperties.Name="{Binding Text, ElementName=DreamerPhaseText}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="DreamerWalkCountText" x:Uid="DashDreamerWalksInitial" FontSize="13"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               AutomationProperties.Name="{Binding Text, ElementName=DreamerWalkCountText}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="DreamerSignalText" x:Uid="DashDreamerSignalInitial" FontSize="13"
                               Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap"
                               AutomationProperties.Name="{Binding Text, ElementName=DreamerSignalText}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="DreamerLocalDigestText" x:Uid="DashDreamerLocalDigestInitial" FontSize="13"
                               Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap"
                               AutomationProperties.Name="{Binding Text, ElementName=DreamerLocalDigestText}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="DreamerPostcardText" x:Uid="DashDreamerPostcardInitial" FontSize="12"
                               Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap" MaxHeight="80"
                               AutomationProperties.Name="{Binding Text, ElementName=DreamerPostcardText}"
                               AutomationProperties.LiveSetting="Polite"/>
                </StackPanel>
            </Border>

            <!-- ═══ Platforms & Model Row ═══ -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Platforms & Services -->
                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock x:Uid="DashPlatformsCardTitle" FontSize="16" FontWeight="SemiBold"/>

                        <!-- Platform badges -->
                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="DashPlatformsMessaging" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <StackPanel x:Name="PlatformBadges" Orientation="Horizontal" Spacing="8">
                                <!-- Populated in code-behind -->
                            </StackPanel>
                        </StackPanel>

                        <!-- Services -->
                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="DashPlatformsServices" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <StackPanel x:Name="ServiceBadges" Orientation="Horizontal" Spacing="8">
                                <!-- Populated in code-behind -->
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Model Info -->
                <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="DashModelCardTitle" FontSize="16" FontWeight="SemiBold"/>

                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="DashboardProviderLabel" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock x:Name="ProviderText" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource AppAccentTextBrush}"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="ChatConnectionModelLabel" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock x:Name="ModelNameText" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="DashOverviewEndpointField" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock x:Name="EndpointText" FontSize="12" TextWrapping="Wrap"
                                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        </StackPanel>

                        <Button x:Uid="DashTestConnectionButton" Click="TestConnection_Click"
                                Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D"
                                Padding="16,8" FontSize="12"/>
                        <TextBlock x:Name="TestConnectionResult" FontSize="11" TextWrapping="Wrap"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ Recent Activity & Paths Row ═══ -->
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Sessions -->
                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock x:Uid="DashRecentActivityTitle" FontSize="16" FontWeight="SemiBold"/>
                            <Button x:Uid="DashOpenChatButton" Click="LaunchHermesChat_Click" FontSize="11" Padding="10,4"
                                    Background="{StaticResource AppAccentGradientBrush}" Foreground="#16110D" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ListView x:Name="RecentSessionsList" Background="Transparent" SelectionMode="None" MaxHeight="250">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4" ColumnDefinitions="Auto,*,Auto">
                                        <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Preview}" FontSize="13" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding MessageCount}" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding TimeAgo}" FontSize="11"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock x:Name="NoSessionsText" x:Uid="DashNoSessionsText"
                                   FontSize="12" Opacity="0.5" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- System Paths -->
                <Border Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="DashSystemCardTitle" FontSize="16" FontWeight="SemiBold"/>

                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="DashboardVersionLabel" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind AppVersion, Mode=OneTime}" FontSize="12" FontFamily="Consolas"
                                       Foreground="{StaticResource AppAccentTextBrush}"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="DashboardHermesHomeLabel" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind HermesHomePath, Mode=OneTime}" FontSize="12" TextWrapping="Wrap" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="DashboardConfigLabel" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock Text="{x:Bind HermesConfigPath, Mode=OneTime}" FontSize="12" TextWrapping="Wrap" FontFamily="Consolas"/>
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="DashSystemSoulsLabel" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock x:Name="ActiveSoulText" FontSize="12" FontFamily="Consolas"
                                       Foreground="{StaticResource AppAccentTextBrush}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="DashOpenLogsSmallButton" Click="OpenLogs_Click" FontSize="11" Padding="10,4"
                                    Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppStrokeBrush}" Foreground="White"/>
                            <Button x:Uid="DashOpenConfigSmallButton" Click="OpenConfig_Click" FontSize="11" Padding="10,4"
                                    Background="{StaticResource AppInsetBrush}" BorderBrush="{StaticResource AppStrokeBrush}" Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- ═══ Usage Insights ═══ -->
            <Border x:Name="InsightsPanel" Style="{StaticResource SurfaceCardStyle}" Visibility="Collapsed">
                <StackPanel Spacing="14">
                    <TextBlock x:Uid="DashInsightsTitle" FontSize="16" FontWeight="SemiBold"/>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Total Messages -->
                        <StackPanel Spacing="2">
                            <TextBlock x:Uid="DashInsightsTotalTurns" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock x:Name="InsightsTurnsText" Text="0" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AppAccentTextBrush}"/>
                        </StackPanel>

                        <!-- Total Tool Calls -->
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock x:Uid="DashInsightsToolCalls" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock x:Name="InsightsToolCallsText" Text="0" FontSize="22" FontWeight="Bold"
                                       Foreground="#6BCB77"/>
                        </StackPanel>

                        <!-- Avg Response Time -->
                        <StackPanel Grid.Column="2" Spacing="2">
                            <TextBlock x:Uid="DashInsightsEstCost" FontSize="11" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <TextBlock x:Name="InsightsCostText" Text="$0.00" FontSize="22" FontWeight="Bold"
                                       Foreground="#818CF8"/>
                        </StackPanel>
                    </Grid>

                    <!-- Top Tools -->
                    <StackPanel Spacing="4">
                        <TextBlock x:Uid="DashInsightsTopTools" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                        <StackPanel x:Name="TopToolsList" Spacing="2"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
