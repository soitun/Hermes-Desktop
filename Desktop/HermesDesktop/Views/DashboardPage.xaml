<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    mc:Ignorable="d"
    NavigationCacheMode="Required">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20,12,24,28" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="292" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="14">
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <Grid ColumnSpacing="16" Padding="18,18,18,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Grid.Column="0"
                            Background="{StaticResource AppHeroAccentBrush}"
                            CornerRadius="999" />

                        <StackPanel
                            Grid.Column="1"
                            Spacing="12">
                            <TextBlock
                                x:Uid="DashboardHeroEyebrow"
                                Style="{StaticResource PageEyebrowTextStyle}" />
                            <TextBlock
                                x:Uid="DashboardHeroTitle"
                                Style="{StaticResource PageTitleTextStyle}"
                                MaxWidth="760" />
                            <TextBlock
                                x:Uid="DashboardHeroSubtitle"
                                Style="{StaticResource BodySecondaryTextStyle}"
                                MaxWidth="760" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button
                                    x:Uid="DashboardLaunchChatButton"
                                    AccessKey="L"
                                    AutomationProperties.AutomationId="DashboardLaunchChatButton"
                                    Background="{StaticResource AppAccentBrush}"
                                    BorderBrush="{StaticResource AppAccentBrush}"
                                    Click="LaunchHermesChat_Click"
                                    Foreground="#0E1720" />
                                <Button
                                    x:Uid="DashboardOpenLogsButton"
                                    AccessKey="G"
                                    AutomationProperties.AutomationId="DashboardOpenLogsButton"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Click="OpenLogs_Click"
                                    Foreground="White" />
                                <Button
                                    x:Uid="DashboardOpenConfigButton"
                                    AccessKey="C"
                                    AutomationProperties.AutomationId="DashboardOpenConfigButton"
                                    Background="{StaticResource AppInsetBrush}"
                                    BorderBrush="{StaticResource AppStrokeBrush}"
                                    Click="OpenConfig_Click"
                                    Foreground="White" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            x:Uid="DashboardPathsSectionTitle"
                            Grid.Row="0"
                            Margin="18,16,18,14"
                            Style="{StaticResource SectionTitleTextStyle}" />

                        <Border
                            Grid.Row="1"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="0,1,0,0" />

                        <Grid
                            Grid.Row="1"
                            Margin="18,16,18,16"
                            ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="152" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="DashboardHermesHomeLabel"
                                Grid.Column="0"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind HermesHomePath, Mode=OneTime}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Border
                            Grid.Row="2"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="0,1,0,0" />

                        <Grid
                            Grid.Row="2"
                            Margin="18,16,18,16"
                            ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="152" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="DashboardConfigLabel"
                                Grid.Column="0"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind HermesConfigPath, Mode=OneTime}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Border
                            Grid.Row="3"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="0,1,0,0" />

                        <Grid
                            Grid.Row="3"
                            Margin="18,16,18,16"
                            ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="152" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="DashboardLogsLabel"
                                Grid.Column="0"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind HermesLogsPath, Mode=OneTime}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>

                        <Border
                            Grid.Row="4"
                            BorderBrush="{StaticResource AppStrokeBrush}"
                            BorderThickness="0,1,0,0" />

                        <Grid
                            Grid.Row="4"
                            Margin="18,16,18,18"
                            ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="152" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Uid="DashboardWorkspaceLabel"
                                Grid.Column="0"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind HermesWorkspacePath, Mode=OneTime}"
                                TextWrapping="WrapWholeWords" />
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>

            <Border
                Grid.Column="1"
                Style="{StaticResource SurfaceCardStyle}"
                Padding="0">
                <StackPanel>
                    <StackPanel
                        Orientation="Horizontal"
                        Padding="16,14,16,10"
                        Spacing="14">
                        <StackPanel Spacing="5">
                            <TextBlock
                                Text="Status"
                                Foreground="{StaticResource AppAccentTextBrush}"
                                Style="{StaticResource LabelTextStyle}" />
                            <Border
                                Width="38"
                                Height="2"
                                Background="{StaticResource AppAccentBrush}"
                                CornerRadius="999" />
                        </StackPanel>
                        <TextBlock
                            Text="Model"
                            Style="{StaticResource LabelTextStyle}" />
                        <TextBlock
                            Text="Shell"
                            Style="{StaticResource LabelTextStyle}" />
                    </StackPanel>

                    <Border
                        BorderBrush="{StaticResource AppStrokeBrush}"
                        BorderThickness="0,1,0,0" />

                    <StackPanel Padding="16,16,16,14" Spacing="6">
                        <TextBlock
                            x:Uid="DashboardProviderLabel"
                            Style="{StaticResource LabelTextStyle}" />
                        <TextBlock
                            Style="{StaticResource MetricValueTextStyle}"
                            Text="{x:Bind ModelProvider, Mode=OneTime}" />
                        <TextBlock
                            Style="{StaticResource BodySecondaryTextStyle}"
                            Text="{x:Bind InstallSummary, Mode=OneTime}" />
                    </StackPanel>

                    <Border
                        BorderBrush="{StaticResource AppStrokeBrush}"
                        BorderThickness="0,1,0,0" />

                    <StackPanel Padding="16,16,16,14" Spacing="6">
                        <TextBlock
                            x:Uid="DashboardModelLabel"
                            Style="{StaticResource LabelTextStyle}" />
                        <TextBlock
                            Style="{StaticResource MetricValueTextStyle}"
                            Text="{x:Bind DefaultModel, Mode=OneTime}" />
                        <TextBlock
                            Style="{StaticResource BodySecondaryTextStyle}"
                            Text="{x:Bind BaseUrl, Mode=OneTime}" />
                    </StackPanel>

                    <Border
                        BorderBrush="{StaticResource AppStrokeBrush}"
                        BorderThickness="0,1,0,0" />

                    <StackPanel Padding="16,16,16,14" Spacing="6">
                        <TextBlock
                            x:Uid="DashboardGatewayLabel"
                            Style="{StaticResource LabelTextStyle}" />
                        <TextBlock
                            Style="{StaticResource MetricValueTextStyle}"
                            Text="{x:Bind MessagingState, Mode=OneTime}" />
                        <TextBlock
                            Style="{StaticResource BodySecondaryTextStyle}"
                            Text="{x:Bind MessagingSummary, Mode=OneTime}" />
                    </StackPanel>

                    <Border
                        BorderBrush="{StaticResource AppStrokeBrush}"
                        BorderThickness="0,1,0,0" />

                    <StackPanel Padding="16,16,16,18" Spacing="12">
                        <TextBlock
                            x:Uid="DashboardStatusSectionTitle"
                            Style="{StaticResource SectionTitleTextStyle}" />
                        <StackPanel Spacing="8">
                            <TextBlock
                                x:Uid="DashboardCliLabel"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Text="{x:Bind CliState, Mode=OneTime}" />
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock
                                x:Uid="DashboardPortLabel"
                                Style="{StaticResource LabelTextStyle}" />
                            <TextBlock Text="{x:Bind ModelPort, Mode=OneTime}" />
                        </StackPanel>
                        <StackPanel Spacing="10">
                            <TextBlock
                                x:Uid="DashboardQuickNotesTitle"
                                Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock
                                x:Uid="DashboardQuickNotesLine1"
                                Style="{StaticResource BodySecondaryTextStyle}" />
                            <TextBlock
                                x:Uid="DashboardQuickNotesLine2"
                                Style="{StaticResource BodySecondaryTextStyle}" />
                            <TextBlock
                                x:Uid="DashboardQuickNotesLine3"
                                Style="{StaticResource BodySecondaryTextStyle}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
