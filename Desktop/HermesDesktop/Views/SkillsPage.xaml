<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.SkillsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid Padding="32,24,32,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Skills" Style="{StaticResource PageEyebrowTextStyle}"/>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Skill Library" FontSize="22" FontWeight="SemiBold"/>
                    <Border Background="{StaticResource AppOutlineBrush}" CornerRadius="8" Padding="10,4" VerticalAlignment="Center">
                        <TextBlock x:Name="SkillCountBadge" Text="0 skills" FontSize="12"
                                   Foreground="{StaticResource AppAccentTextBrush}"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Browse, search, and preview all available agent capabilities"
                           FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}"/>
            </StackPanel>

            <!-- Sort dropdown -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                <TextBlock Text="Sort:" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <ComboBox x:Name="SortSelector" SelectedIndex="0" SelectionChanged="SortSelector_SelectionChanged"
                          FontSize="12" MinWidth="120"
                          Style="{StaticResource AppComboBoxStyle}">
                    <ComboBoxItem Content="Name (A-Z)" Tag="NameAsc"/>
                    <ComboBoxItem Content="Name (Z-A)" Tag="NameDesc"/>
                    <ComboBoxItem Content="Category" Tag="Category"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Search + category chips -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBox x:Name="SearchBox" PlaceholderText="&#xE721; Search skills by name, description, category, or tools..."
                     FontSize="13" Margin="0,0,0,10" TextChanged="SearchBox_TextChanged"
                     Style="{StaticResource AppTextBoxStyle}"/>
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="CategoryChips" Orientation="Horizontal" Spacing="6"/>
            </ScrollViewer>
        </Grid>

        <!-- Two-column layout -->
        <Grid Grid.Row="3" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" MinWidth="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Skill list -->
            <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock x:Name="ListHeader" Text="All Skills" FontSize="16" FontWeight="SemiBold" Margin="16,12"
                               Foreground="{StaticResource AppAccentTextBrush}"/>
                    <ListView Grid.Row="1" x:Name="SkillsList" Background="Transparent" Padding="8"
                              SelectionChanged="SkillsList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4" Padding="8,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch IsOn="{Binding IsEnabled, Mode=TwoWay}"
                                                  Toggled="SkillToggle_Toggled"
                                                  Tag="{Binding Name}"
                                                  MinWidth="0" Width="44" OnContent="" OffContent=""
                                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                        <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                                   MaxLines="2" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right" Spacing="4">
                                        <Border Background="{Binding BadgeBackground}" CornerRadius="4" Padding="8,2"
                                                HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Category}" FontSize="10"
                                                       Foreground="{Binding BadgeForeground}"/>
                                        </Border>
                                        <TextBlock Text="{Binding ToolCount}" FontSize="10"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Right: Install + Skill preview -->
            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Install / Hub panel -->
                <Border Style="{StaticResource SurfaceCardStyle}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <TextBlock x:Name="InstallHeader" Text="Install a skill" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource AppAccentTextBrush}"/>
                            <Border x:Name="QuarantineBadge" Background="#3C1A1A" CornerRadius="6" Padding="8,2"
                                    VerticalAlignment="Center" Visibility="Collapsed">
                                <TextBlock x:Name="QuarantineBadgeText" FontSize="11" Foreground="#E07070"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="InstallSubtitle"
                                   Text="Paste a raw URL to a SKILL.md file or a GitHub repo path (owner/repo)."
                                   FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap"/>
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InstallNameBox" PlaceholderText="skill-name" MinWidth="160"
                                     Background="{StaticResource AppInsetBrush}"
                                     BorderBrush="{StaticResource AppStrokeBrush}"/>
                            <TextBox Grid.Column="1" x:Name="InstallUrlBox"
                                     PlaceholderText="https://raw.githubusercontent.com/owner/repo/main/SKILL.md"
                                     Background="{StaticResource AppInsetBrush}"
                                     BorderBrush="{StaticResource AppStrokeBrush}"/>
                            <Button Grid.Column="2" x:Name="InstallButton" Content="Install"
                                    Click="InstallSkill_Click"
                                    Background="{StaticResource AppAccentBrush}" Foreground="#16110D"/>
                            <Button Grid.Column="3" x:Name="BrowseHubButton" Content="Browse"
                                    Click="BrowseHub_Click"
                                    Background="{StaticResource AppInsetBrush}"/>
                        </Grid>
                        <TextBlock x:Name="InstallStatus" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource AppTextSecondaryBrush}" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Skill preview -->
                <Border Grid.Row="1" Style="{StaticResource SurfaceCardStyle}">
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PreviewTitle" Text="Select a skill to preview" FontSize="18"
                                       FontWeight="SemiBold" Foreground="White" Margin="0,0,0,4"/>
                            <Button Grid.Column="1" x:Name="DeleteSkillButton" Content="Delete"
                                    Click="DeleteSkill_Click" IsEnabled="False"
                                    Background="#3C1A1A" Foreground="#E07070"/>
                        </Grid>
                        <TextBlock x:Name="PreviewDescription" Grid.Row="1" FontSize="13" TextWrapping="Wrap"
                                   Foreground="{StaticResource AppTextSecondaryBrush}" Margin="0,0,0,12"
                                   Text="Click a skill from the list to see its full system prompt here."/>
                        <!-- Metadata chips -->
                        <StackPanel x:Name="PreviewChips" Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                    Margin="0,0,0,16" Visibility="Collapsed">
                            <Border Background="{StaticResource AppOutlineBrush}" CornerRadius="4" Padding="8,4">
                                <TextBlock x:Name="PreviewCategoryChip" FontSize="11"
                                           Foreground="{StaticResource AppAccentTextBrush}"/>
                            </Border>
                            <Border Background="{StaticResource AppInsetBrush}" CornerRadius="4" Padding="8,4">
                                <TextBlock x:Name="PreviewToolsChip" FontSize="11" Foreground="White"/>
                            </Border>
                            <Border x:Name="PreviewStateChip" Background="#1A3C28" CornerRadius="4" Padding="8,4">
                                <TextBlock x:Name="PreviewStateChipText" FontSize="11" Foreground="#60E090" Text="Enabled"/>
                            </Border>
                        </StackPanel>
                        <ScrollViewer Grid.Row="3">
                            <TextBlock x:Name="PreviewContent" FontSize="13" FontFamily="Consolas" TextWrapping="Wrap"
                                       Foreground="{StaticResource AppTextSecondaryBrush}" IsTextSelectionEnabled="True"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
