<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HermesDesktop.Views.McpPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,24,32,40" Spacing="20" MaxWidth="960">
            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="McpPageEyebrow" Style="{StaticResource PageEyebrowTextStyle}" />
                    <TextBlock x:Uid="McpPageTitle" Style="{StaticResource PageTitleTextStyle}" MaxWidth="920" />
                    <TextBlock
                        x:Uid="McpPageIntro"
                        Style="{StaticResource BodySecondaryTextStyle}"
                        MaxWidth="920"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="McpPathsSectionTitle" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock x:Uid="McpPathsHint" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="ConfigPathsPanel" Spacing="6" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="McpStatusSectionTitle" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock x:Uid="McpStatusHint" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="ServerStatusPanel" Spacing="8" />
                    <Button
                        x:Uid="McpRefreshButton"
                        Click="Refresh_Click"
                        Background="{StaticResource AppAccentGradientBrush}"
                        BorderBrush="{StaticResource AppOutlineBrush}"
                        Foreground="#16110D"
                        Padding="16,8"
                        HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SurfaceCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock x:Uid="McpIssuesSectionTitle" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock x:Uid="McpIssuesHint" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel x:Name="LoadIssuesPanel" Spacing="6" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <HyperlinkButton
                    x:Uid="McpDocsLink"
                    NavigateUri="https://github.com/RedWoodOG/Hermes-Desktop/blob/main/docs/mcp.md" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
