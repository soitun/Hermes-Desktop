<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="HermesDesktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{StaticResource AppWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Grid.Row="0">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <InfoBar
            x:Name="UpdateAvailableInfoBar"
            Grid.Row="1"
            Margin="12,8,12,0"
            Closed="OnUpdateBannerClosed"
            IsClosable="True"
            IsOpen="False"
            Severity="Informational"
            Visibility="Collapsed">
            <InfoBar.ActionButton>
                <Button
                    x:Uid="UpdateBannerOpenReleaseButton"
                    Click="OnUpdateBannerOpenReleaseClick"
                    Background="{StaticResource AppAccentGradientBrush}"
                    BorderBrush="{StaticResource AppOutlineBrush}"
                    Foreground="#16110D"
                    Padding="12,6" />
            </InfoBar.ActionButton>
        </InfoBar>

        <NavigationView
            x:Name="ShellNavigation"
            x:Uid="ShellNavigation"
            Grid.Row="2"
            AlwaysShowHeader="False"
            Background="{StaticResource AppWindowBackgroundBrush}"
            CompactPaneLength="46"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            OpenPaneLength="228"
            PaneDisplayMode="Left"
            SelectionChanged="OnNavigationSelectionChanged">
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#141920" />
                <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#141920" />
                <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="#141920" />
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="#0F1318" />
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="#202731" />
                <SolidColorBrush x:Key="NavigationViewItemForeground" Color="#E8EEF7" />
                <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#FFD700" />
                <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="#FFFFFF" />
                <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="#FFD700" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#23211A" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#2A2718" />
                <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#1E2530" />
                <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#FFD700" />
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="DashboardNavItem"
                    x:Uid="DashboardNavItem"
                    Tag="dashboard">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="ChatNavItem"
                    x:Uid="ChatNavItem"
                    Tag="chat">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Message" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="AgentNavItem"
                    x:Uid="AgentNavItem"
                    Tag="agent">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ContactInfo" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="SkillsNavItem"
                    x:Uid="SkillsNavItem"
                    Tag="skills">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="MemoryNavItem"
                    x:Uid="MemoryNavItem"
                    Tag="memory">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Document" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="BuddyNavItem"
                    x:Uid="BuddyNavItem"
                    Tag="buddy">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Emoji2" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="IntegrationsNavItem"
                    x:Uid="IntegrationsNavItem"
                    Tag="integrations">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="People" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="McpNavItem"
                    x:Uid="McpNavItem"
                    Tag="mcp">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE943;" FontFamily="Segoe MDL2 Assets" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="DiagnosticsNavItem"
                    x:Uid="DiagnosticsNavItem"
                    Tag="diagnostics">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Help" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    x:Name="SettingsNavItem"
                    x:Uid="SettingsNavItem"
                    Tag="settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
